{
  "name": "matchday-mesh",
  "version": "0.1.0",
  "description": "Serverless football watch parties with P2P fan passes, live predictions, QR check-ins, and USDt pool cards.",
  "type": "module",
  "main": "index.cjs",
  "license": "MIT",
  "pear": {
    "name": "matchday-mesh",
    "pre": "pear-electron/pre",
    "gui": {
      "main": "index.html",
      "width": 1280,
      "height": 820,
      "minWidth": 900,
      "minHeight": 680,
      "backgroundColor": "#101211"
    },
    "stage": {
      "ignore": [
        "/.git",
        "/coverage",
        "/docs",
        "/matchday-pear-proof.json",
        "/matchday-release-proof.json",
        "/pearbrowser-catalog-data",
        "/test",
        "/scripts/validate-publish-surface.mjs"
      ]
    }
  },
  "scripts": {
    "dev": "pear run --dev .",
    "dev:devtools": "pear run --dev --devtools .",
    "preview": "node scripts/serve.mjs",
    "test": "node --test",
    "validate:publish": "node scripts/validate-publish-surface.mjs",
    "check": "npm test && npm run validate:publish",
    "link:new": "pear touch",
    "stage": "pear stage \"$PEAR_LINK\" .",
    "release": "pear release \"$PEAR_LINK\"",
    "seed": "pear seed \"$PEAR_LINK\""
  },
  "dependencies": {
    "b4a": "^1.8.0",
    "corestore": "^6.18.4",
    "hyperbee": "^2.27.3",
    "pear-bridge": "^1.2.5",
    "pear-electron": "^1.7.28"
  },
  "devDependencies": {}
}
